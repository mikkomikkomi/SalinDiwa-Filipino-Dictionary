{
  "expo": {
    "name": "SalinDiwa",
    "slug": "FilipinoDictionary",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/salindiwa.png",
    "scheme": "filipinodictionary",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/salindiwa.png",
        "backgroundColor": "#FFFFFF"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.mikkomikkomi.FilipinoDictionary"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/salindiwa.png",
          "imageWidth": 275,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF",
          "dark": {
            "backgroundColor": "#FFFFFF"
          }
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "89e131fc-6530-47f1-a109-2f96dea56555"
      }
    }
  }
}